# Sample nginx config for self-hosting the static SPA in Frontend/dist/.
# Drop this in /etc/nginx/sites-available/quianne, symlink it to
# sites-enabled, run `nginx -t && systemctl reload nginx`.

server {
    listen 80;
    listen [::]:80;
    server_name quianne.example.com;

    # Redirect all HTTP to HTTPS — assumes you've terminated TLS via certbot.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name quianne.example.com;

    root /var/www/quianne/dist;
    index index.html;

    # TLS — replace with your certbot paths.
    ssl_certificate     /etc/letsencrypt/live/quianne.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/quianne.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers off;

    # Security headers — same set as Frontend/public/_headers.
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests" always;
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()" always;
    add_header Cross-Origin-Opener-Policy "same-origin" always;
    add_header Cross-Origin-Resource-Policy "same-origin" always;

    # Long-cache hashed assets emitted by Vite (filenames contain content hash).
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    # Service worker must NOT be cached so updates ship immediately.
    location = /sw.js {
        expires off;
        add_header Cache-Control "public, max-age=0, must-revalidate";
    }

    # Static files — try them, otherwise fall back to index.html (SPA routing).
    location / {
        try_files $uri $uri/ /index.html;
        # Don't cache HTML — let new deploys be picked up immediately.
        add_header Cache-Control "public, max-age=0, must-revalidate" always;
    }

    # Tighten error handling
    error_page 404 /index.html;

    # Gzip / brotli — adjust to what your nginx build supports.
    gzip on;
    gzip_vary on;
    gzip_types text/plain text/css application/json application/javascript application/manifest+json image/svg+xml;
}
